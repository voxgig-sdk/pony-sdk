# Guide

guide: {
  metrics: count: entity: 6
  metrics: count: path: 17
  metrics: count: method: 17

  entity: character: {
    path: "/character/all": {
      action: "all": {}
      op: list: method: *GET
    }
    path: "/character/by-kind/{kind}": {
      op: load: method: *GET
    }
    path: "/character/by-occupation/{occupation}": {
      op: load: method: *GET
    }
    path: "/character/by-residence/{residence}": {
      op: load: method: *GET
    }
    path: "/character/{character}": {
      rename: param: "character": *"id"
      op: load: method: *GET
    }
  }

