    }
    path: "/episode/by-season/{season}": {
      op: load: method: *GET
    }
    path: "/episode/{episode}": {
      rename: param: "episode": *"id"
      op: load: method: *GET
    }
  }

  entity: image: {
    path: "/image/all": {
      action: "all": {}
      op: list: method: *GET
    }
  }

  entity: kind: {
    path: "/kind/all": {
      action: "all": {}
      op: list: method: *GET
