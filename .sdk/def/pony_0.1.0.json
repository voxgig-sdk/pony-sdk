  "components": {
    "parameters": {
      "limitParam": {
        "name": "limit",
        "in": "query",
        "description": "Limit of the response data array",
        "required": false,
        "schema": {
          "type": "integer",
          "default": 50
        }
      },
      "offsetParam": {
        "name": "offset",
        "in": "query",
        "description": "Offset of the response data array (SQL-like behavior)",
        "required": false,
        "schema": {
          "type": "integer",
          "default": 0
        }
      }
    },
    "schemas": {
      "Character": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique character identifier"
          },
          "name": {
            "type": "string",
            "description": "The name of this character"
          },
          "alias": {
            "type": "string",
            "description": "Possible alias of this character"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the MLP fandom wiki about this character"
          },
          "sex": {
            "type": "string",
            "description": "Sex of this character"
          },
          "residence": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ],
            "description": "Residence of this character"
          },
          "occupation": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ],
            "description": "Occupation of this character"
          },
          "kind": {
            "type": "array",
            "description": "All possible kinds of this character",
            "items": {
              "oneOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "string"
                },
                {
                  "type": "array",
                  "items": {}
                }
              ]
            }
          },
          "image": {
            "type": "array",
            "description": "All images of possible kinds and transformations of this character",
            "items": {
              "oneOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "string",
                  "format": "uri"
                },
                {
                  "type": "array",
                  "items": {}
                }
              ]
            }
          }
        },
        "required": [
          "id",
          "name",
          "url"
        ]
      },
      "Episode": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique episode identifier"
          },
          "name": {
            "type": "string",
            "description": "Name of the episode"
          },
          "season": {
            "type": "integer",
            "description": "Season number"
          },
          "episode": {
            "type": "integer",
            "description": "Episode number within the season"
          },
          "overall": {
            "type": "integer",
            "description": "Overall episode number"
          },
          "airdate": {
            "type": "string",
            "format": "date",
            "description": "Air date of the episode"
          },
          "thumbnail": {
            "type": "string",
            "format": "uri",
            "description": "Thumbnail image URL"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Wiki URL"
          }
        }
      },
      "Song": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique song identifier"
          },
          "name": {
            "type": "string",
            "description": "Name of the song"
          },
          "length": {
            "type": "string",
            "description": "Length of the song"
          },
          "video_url": {
            "type": "string",
            "format": "uri",
            "description": "Video URL"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Wiki URL"
          }
        }
      },
      "Comics": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique comics story identifier"
          },
          "name": {
            "type": "string",
            "description": "Name of the comics story"
          },
          "series": {
            "type": "string",
            "description": "Series name"
          },
          "cover_image": {
            "type": "string",
            "format": "uri",
            "description": "Cover image URL"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Wiki URL"
          },
          "issues": {
            "type": "array",
            "description": "Issues contained in this story",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Kind": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique kind identifier"
          },
          "name": {
            "type": "string",
            "description": "Name of the kind"
          },
          "comment": {
            "type": "string",
            "description": "Comment about the kind"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Wiki URL"
          }
        }
      },
      "Image": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique image identifier"
          },
          "name": {
            "type": "string",
            "description": "Image name"
          },
          "description": {
            "type": "string",
            "description": "Image description"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Image URL"
          }
        }
      },
      "ApiResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "data": {
            "type": "array",
            "description": "Array of found objects. Empty array if no objects found.",
            "items": {
              "type": "object"
            }
          },
          "warning": {
            "type": "string",
            "description": "Warning messages separated by newline"
          },
          "error": {
            "type": "string",
            "description": "First error message"
          }
        },
        "required": [
          "status"
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "error": {
            "type": "string",
            "description": "Error message"
          }
