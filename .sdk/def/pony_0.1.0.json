              "oneOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "string"
                }
              ]
            },
            "examples": {
              "string": {
                "value": "dragon",
                "summary": "Search by kind name"
              },
              "integer": {
                "value": 1,
                "summary": "Search by kind ID"
              }
            }
          },
          {
            "$ref": "#/components/parameters/limitParam"
          },
          {
            "$ref": "#/components/parameters/offsetParam"
