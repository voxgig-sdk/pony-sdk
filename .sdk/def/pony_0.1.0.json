{
  "openapi": "3.0.3",
  "info": {
    "title": "Pony API",
    "description": "The Pony API provides access to detailed information about characters, episodes, songs, and comics from the animated series My Little Pony: Friendship is Magic. This RESTful API allows users to search for data by various attributes, making it an essential tool for fans and developers alike.",
    "version": "1.0.0",
    "contact": {
      "url": "https://ponyapi.net/"
    }
  },
  "servers": [
    {
      "url": "http://ponyapi.net/v1",
      "description": "Production server"
    }
  ],
  "paths": {
    "/character/all": {
      "get": {
        "summary": "Get all characters",
        "description": "Return list of all characters with optional limit and offset parameters",
        "operationId": "getAllCharacters",
        "tags": [
          "Character"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/limitParam"
          },
          {
            "$ref": "#/components/parameters/offsetParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/CharacterResponse"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "405": {
            "$ref": "#/components/responses/MethodNotAllowed"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/character/{character}": {
      "get": {
        "summary": "Get character by ID or name",
        "description": "Search character by CharacterID (integer) or Name (string). A string query is also searched in the Alias column.",
        "operationId": "getCharacter",
        "tags": [
          "Character"
        ],
        "parameters": [
          {
            "name": "character",
            "in": "path",
            "required": true,
            "description": "Character ID (integer) or name (string)",
            "schema": {
              "oneOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "string"
                }
              ]
            }
          },
          {
            "$ref": "#/components/parameters/limitParam"
          },
          {
            "$ref": "#/components/parameters/offsetParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/CharacterResponse"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "405": {
            "$ref": "#/components/responses/MethodNotAllowed"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
